{
  "name": "ai-shortvideo",
  "version": "0.1.0",
  "private": true,
  "description": "AI novel generation and short-video production workspace.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:admin": "npm run dev -w apps/admin-web",
    "build:admin": "npm run build -w apps/admin-web",
    "dev:api": "npm run dev -w apps/api",
    "build:api": "npm run build -w apps/api",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run build -w @ai-shortvideo/shared && npm run typecheck --workspaces --if-present",
    "governance:git-budget": "node scripts/remediation-governance.mjs git-budget",
    "governance:sla": "node scripts/remediation-governance.mjs sla",
    "test:governance": "node --test scripts/remediation-governance.test.mjs",
    "e2e:rp01a": "npm run build -w @ai-shortvideo/shared && node scripts/e2e/run-playwright-backend-e2e.mjs",
    "test:e2e:rp01a": "node --test scripts/e2e/*.test.mjs"
  },
  "devDependencies": {
    "@playwright/test": "1.56.1"
  }
}
